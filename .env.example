# ==========================================
# 1. DOCKER DATABASE (Local PostgreSQL)
# ==========================================
# These configure the local Postgres container created by 'docker compose up'
LOCAL_DB_NAME=consulting_db
LOCAL_DB_USER=admin
LOCAL_DB_PASSWORD=localpassword
LOCAL_DB_PORT=5432

# ==========================================
# 2. SPRING BOOT APP (Database Connection)
# ==========================================
# If running `docker compose up`, Docker automatically points the backend to the local DB.
# Uncomment the 3 lines below ONLY if you are running the backend locally from your IDE 
# (IntelliJ/Eclipse) without Docker, but want to connect to the Docker DB container:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/consulting_db
# SPRING_DATASOURCE_USERNAME=admin
# SPRING_DATASOURCE_PASSWORD=localpassword

# ==========================================
# 3. REMOTE NEON DATABASE (Cloud PostgreSQL)
# ==========================================
# Uncomment everything below to connect your backend OR tests to Neon instead of local DB/H2:
# SPRING_DATASOURCE_URL=jdbc:postgresql://<your-neon-host>/<db-name>?sslmode=require&channel_binding=require
# SPRING_DATASOURCE_USERNAME=<your-neon-username>
# SPRING_DATASOURCE_PASSWORD=<your-neon-password>
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

# --- FOR TESTS ONLY (Uncomment alongside Neon creds to test against Neon) ---
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
# SPRING_TEST_DATABASE_REPLACE=none
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
# SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ==========================================
# 4. APP CONFIGURATION
# ==========================================
SPRING_PORT=8080
JWT_SECRET=replace_with_a_secure_jwt_secret_key

# Google Gemini — used by POST /api/agent/chat (backend). Create a key at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-flash

# Frontend
REACT_APP_API_URL=http://localhost:8080